pipeline{
    agent any

    tools {
        maven 'mymaven'
    }

    environment {
        NAME = 'Dhanush'
    }
    parameters {
        choice choices: ['dev', 'prod'], description: 'select environment', name: 'select_env'
    }

    stages{
        stage('build'){
            steps{
                sh 'mvn clean package -DskipTests=true'
                echo "Hello ${NAME}, the build has been completed successfully"
            }
        }
        stage('parallel test'){
            parallel{
                stage('test A'){
                    steps{
                        sh 'mvn test'
                        echo "Hello ${NAME}, Test A has been executed successfully"
                    }

                }
                stage('test B'){
                    steps{
                        sh 'mvn test'
                        echo "Hello ${NAME}, Test B has been executed successfully"
                    }

                }
            }
        }
    }
    post{
        success{
            archiveArtifacts artifacts: 'target/*.war'
            echo "Congratulations ${NAME}, the pipeline has been executed successfully"
        }
    }
}
