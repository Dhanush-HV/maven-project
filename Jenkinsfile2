pipeline{
    agent any

    tools {
        maven 'mymaven'
    }

    environment {
        NAME = 'Dhanush'
    }
    parameters {
        choice choices: ['dev', 'prod'], description: 'select environment', name: 'select_env'
    }

    stages{
        stage('build'){
            steps{
                sh 'mvn clean package -DskipTests=true'
               
            }
        }
        stage('parallel test'){
            parallel{
                stage('test A'){
                    steps{
                        sh 'mvn test'
                        
                    }

                }
                stage('test B'){
                    steps{
                        sh 'mvn test'
                       
                    }

                }
            }
        }
    }
    post{
        success{
            archiveArtifacts artifacts: 'target/*.war'
            
        }
    }
}
